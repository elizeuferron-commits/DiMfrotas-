rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'elizeuferron@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    
    function isManager() { 
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager'); 
    }
    
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 100 &&
             data.role in ['admin', 'manager', 'driver', 'Dono / Proprietário', 'Gestor de Frotas', 'Coordenador Logístico', 'Administrativo', 'Motorista', 'Limpeza / Conservação', 'Visitante'] &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 30000000);
    }

    function isValidVehicle(data) {
      return data.plate is string && data.plate.size() <= 10 &&
             data.model is string && data.model.size() <= 100 &&
             data.type in ['van', 'bus'] &&
             data.capacity is number &&
             data.currentOdometer is number &&
             data.status in ['available', 'maintenance', 'trip'] &&
             (data.get('updatedAt', '') is string) &&
             (data.get('photoUrl', '') is string && data.get('photoUrl', '').size() <= 30000000);
    }

    function isValidFinancial(data) {
      return data.type in ['payable', 'receivable'] &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 1000 &&
             data.amount is number &&
             data.dueDate is string &&
             data.status in ['pending', 'paid', 'overdue'] &&
             data.createdAt is string;
    }

    function isValidTrip(data) {
      return data.vehicleId is string && isValidId(data.vehicleId) &&
             data.driverId is string && isValidId(data.driverId) &&
             data.title is string && data.title.size() <= 100 &&
             data.status in ['scheduled', 'active', 'completed', 'cancelled'] &&
             data.startDate is string &&
             data.tripType in ['state', 'interstate', 'mercosur'];
    }

    function isValidDashboardMessage(data) {
      return data.text is string && data.text.size() <= 1000 &&
             data.sender is string && data.sender.size() <= 100 &&
             data.timestamp is timestamp;
    }

    function isValidStockItem(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.quantity is number &&
             data.unit is string && data.unit.size() <= 20;
    }

    function isValidFuelEntry(data) {
      return data.tankId is string && isValidId(data.tankId) &&
             data.quantity is number &&
             data.cost is number &&
             data.timestamp is string;
    }

    function isValidMediaShare(data) {
      return data.url is string && data.url.size() <= 30000000 &&
             data.type in ['image', 'video'] &&
             data.ownerId == request.auth.uid &&
             data.ownerName is string &&
             (data.get('caption', '') is string && data.get('caption', '').size() <= 1000) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidNewsItem(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.authorId == request.auth.uid &&
             data.authorName is string &&
             (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 30000000) &&
             (data.get('isUrgent', false) is bool) &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    function isValidJourney(data) {
      return data.employeeId is string && isValidId(data.employeeId) &&
             data.status in ['active', 'on_break', 'completed'] &&
             data.startTime is string &&
             data.date is string;
    }

    function isValidCharteredRoute(data) {
      return data.name is string && data.name.size() <= 100 &&
             data.client is string && data.client.size() <= 100 &&
             data.status in ['active', 'inactive'];
    }

    function isValidCharterClient(data) {
      return data.name is string && data.name.size() <= 100 &&
             (data.get('companyName', '') is string && data.get('companyName', '').size() <= 100) &&
             (data.get('document', '') is string && data.get('document', '').size() <= 50) &&
             (data.get('phone', '') is string && data.get('phone', '').size() <= 50) &&
             (data.get('email', '') is string && data.get('email', '').size() <= 100) &&
             (data.get('address', '') is string && data.get('address', '').size() <= 200) &&
             (data.get('notes', '') is string && data.get('notes', '').size() <= 1000);
    }

    function isValidCharterClientTrip(data) {
      return data.client is string && data.client.size() <= 100 &&
             (data.get('clientId', '') is string || data.get('clientId', '') == null) &&
             data.dateTime is string && data.dateTime.size() <= 50 &&
             (data.get('description', '') is string && data.get('description', '').size() <= 1000) &&
             (data.get('origin', '') is string && data.get('origin', '').size() <= 200) &&
             (data.get('destination', '') is string && data.get('destination', '').size() <= 200) &&
             (data.get('value', 0) is number || data.get('value', 0) is int) &&
             (data.get('driverId', '') is string && data.get('driverId', '').size() <= 128) &&
             (data.get('vehicleId', '') is string && data.get('vehicleId', '').size() <= 100) &&
             (data.get('status', '') is string && data.get('status', '').size() <= 50) &&
             (data.get('paymentStatus', '') is string && data.get('paymentStatus', '').size() <= 50);
    }

    function isValidFeaturedVideo(data) {
      return data.url is string && data.url.size() <= 30000000 &&
             data.title is string && data.title.size() <= 200 &&
             (data.get('type', 'video') is string) &&
             (data.get('createdAt', '') is string || data.get('createdAt', '') is timestamp);
    }

    function isValidProprietorTicket(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 4000 &&
             data.category is string && data.category.size() <= 100 &&
             data.urgency in ['low', 'medium', 'high'] &&
             data.status in ['pending', 'in_progress', 'resolved', 'cancelled'] &&
             data.createdByUid == request.auth.uid &&
             data.createdByName is string &&
             data.createdByEmail is string &&
             data.createdByRole is string &&
             (data.get('vehicleId', '') is string && data.get('vehicleId', '').size() <= 100) &&
             data.replies is list;
    }

    function isValidStorageBackupLog(data) {
      return data.timestamp is string &&
             data.date is string &&
             data.createdBy is string &&
             data.paths is list &&
             data.formats is list &&
             data.collections is list &&
             data.success is bool;
    }

    function isAdministrative() {
      return isSignedIn() && (
        request.auth.token.email == 'elizeuferron@gmail.com' ||
        isAdmin() || 
        isManager() || 
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Dono / Proprietário', 'Gestor de Frotas', 'Coordenador Logístico', 'Administrativo'] ||
            ('permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny(['finance', 'fleet', 'gabinete']))
          )
        )
      );
    }

    function hasModulePermission(module) {
      return isSignedIn() && (
        request.auth.token.email == 'elizeuferron@gmail.com' ||
        isAdmin() ||
        isManager() ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (
            ('permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny([module])) ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Dono / Proprietário' ||
            (module == 'finance' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Administrativo') ||
            (module == 'fleet' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Gestor de Frotas') ||
            (module == 'fleet' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Coordenador Logístico')
          )
        )
      );
    }

    match /test/{docId} {
      allow read: if true;
    }

    // --- Collection Routes ---

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdministrative();
    }

    match /dashboard_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidDashboardMessage(incoming());
      allow update, delete: if isAdministrative() || hasModulePermission('dashboard');
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if (isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'Motorista' || 
        incoming().role == 'driver' ||
        request.auth.token.email == 'elizeuferron@gmail.com'
      )) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin() || isAdministrative()) && isValidUser(incoming()) && (
        isAdmin() || isAdministrative() || (incoming().role == existing().role)
      );
      allow delete: if isAdmin() || isAdministrative();
    }

    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /employees/{employeeId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isAdministrative();
    }

    match /fuel_tanks/{tankId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isAdministrative();
    }

    match /fuel_logs/{logId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || hasModulePermission('fuel');
    }

    match /fuel_entries/{entryId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isAdministrative();
    }

    match /maintenance_logs/{logId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || hasModulePermission('fleet');
    }

    match /financial_transactions/{transactionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || hasModulePermission('finance');
    }

    match /finance_documents/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || hasModulePermission('finance');
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || hasModulePermission('trips');
    }

    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || isAdministrative();
    }

    match /checklists/{checklistId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    match /stock_items/{itemId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /stock_transactions/{txId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isAdministrative();
    }

    match /tire_alerts/{alertId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isAdministrative();
    }

    match /tire_dossiers/{dossierId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin() || isAdministrative();
    }
    
    match /media_shares/{shareId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    match /news_feed/{newsId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative() || (isSignedIn() && existing().authorId == request.auth.uid);
    }

    match /journeys/{journeyId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /chartered_routes/{routeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /charter_clients/{clientId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /charter_client_trips/{tripId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /featured_videos/{videoId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdministrative();
    }

    match /proprietor_tickets/{ticketId} {
      allow get: if isSignedIn() && (resource.data.createdByUid == request.auth.uid || isAdministrative());
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidProprietorTicket(incoming());
      allow update: if isSignedIn() && (
        isAdministrative() || 
        (existing().createdByUid == request.auth.uid && (
          incoming().createdByUid == request.auth.uid
        ))
      );
      allow delete: if isAdministrative();
    }
    
    match /backups/{backupId} {
      allow read, write: if isSignedIn() && request.auth.token.email == 'elizeuferron@gmail.com';
    }

    match /storage_backup_logs/{logId} {
      allow read: if isAdministrative();
      allow create: if isAdministrative() && isValidStorageBackupLog(incoming());
    }

    match /user_devices/{userId} {
      allow read: if isSignedIn() && (resource == null || userId == request.auth.uid || isManager());
      allow create, update: if isSignedIn() && 
        isValidId(userId) && 
        userId == request.auth.uid && 
        incoming().userId == request.auth.uid && 
        incoming().token is string && incoming().token.size() <= 256;
      allow delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    match /users_layouts/{userId} {
      allow read, write: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
